# ═══════════════════════════════════════════════════════════════════════════
# Briefed v2 backend — environment variables
#
# For details on where each key comes from and what manual setup is needed,
# see docs/SETUP_KEYS.md in the repo root.
#
# Keys grouped by phase. Keys WITHOUT a default value next to them are
# required for that phase to function. Optional keys are commented out.
# ═══════════════════════════════════════════════════════════════════════════


# ─── Supabase (database + RLS) ─────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret — only needed for the legacy WS bot-bridge fallback path
SUPABASE_JWT_SECRET=


# ─── Recall.ai (meeting joiner) ────────────────────────────────────────────
# Dashboard: https://www.recall.ai → API Keys
# Pick the region matching your workspace:
#   https://us-east-1.recall.ai | https://eu-central-1.recall.ai | https://ap-northeast-1.recall.ai
RECALL_API_KEY=
RECALL_API_BASE=https://us-east-1.recall.ai


# ─── Public base URL of THIS service ───────────────────────────────────────
# Local dev: use ngrok (e.g. https://abc123.ngrok-free.app)
# Production: your Cloud Run URL (e.g. https://briefed-api-xyz.a.run.app)
# Used to construct webhook URLs that Recall and GitHub call back into.
PUBLIC_API_BASE=

# Optional: shared secret Recall sends as `Authorization: Bearer <secret>`
# Set this in the Recall dashboard under Webhooks → Headers.
# WEBHOOK_SECRET=


# ─── Google Cloud (Vertex AI Gemini + TTS + Embeddings) ────────────────────
# 1. Create a GCP project: https://console.cloud.google.com
# 2. Enable APIs: Vertex AI API, Cloud Text-to-Speech API
# 3. Create a service account with roles: Vertex AI User, Cloud TTS User
# 4. Download the JSON key and point GOOGLE_APPLICATION_CREDENTIALS at it.
#    On Cloud Run, attach the service account directly — leave the path empty.
GCP_PROJECT=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
# Optional: override the post-meeting summary model. Defaults to gemini-2.5-pro.
# VERTEX_GEMINI_MODEL=gemini-2.5-pro
# Optional: override the live Q&A model (used as the LLM inside the Pipecat
# pipeline AND the addressed-to-bot turn-taking classifier). Defaults to flash.
# LIVE_QA_MODEL=gemini-2.5-flash


# ─── CORS ──────────────────────────────────────────────────────────────────
# Browser origins allowed to call this API (comma-separated)
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000


# ─── Unkey (rate limiting for fact-check) ──────────────────────────────────
# Dashboard: https://app.unkey.com
# Create a root key and a ratelimit namespace. Optional — fact-check still
# works without Unkey but caps are not enforced.
# UNKEY_ROOT_KEY=
# UNKEY_API_ID=


# ─── Resend (optional post-meeting email) ──────────────────────────────────
# https://resend.com — required only if agents have send_post_meeting_email=true
# RESEND_API_KEY=
# RESEND_FROM=Briefed <onboarding@resend.dev>


# ─── Bot-page URL ──────────────────────────────────────────────────────────
# Where Recall loads the bot-page via Output Media. After editing
# bot-page/index.html, upload it to your GCS bucket and update this URL.
BOT_PAGE_URL=https://storage.googleapis.com/briefed-bot-page/index.html


# ═══════════════════════════════════════════════════════════════════════════
# Phase 1 — v2 voice pipeline (Deepgram + ElevenLabs)
# Without these, start_meeting falls back to the v1 batch-TTS path.
# ═══════════════════════════════════════════════════════════════════════════

# Deepgram (streaming STT)
# Dashboard: https://console.deepgram.com → API Keys → Create Key (scope: Member or higher)
DEEPGRAM_API_KEY=
# Optional: override the model (defaults to nova-3, currently best for streaming)
# DEEPGRAM_MODEL=nova-3

# ElevenLabs (streaming TTS)
# Dashboard: https://elevenlabs.io/app/settings/api-keys → Create API Key

# Optional: override model and default voice
# ELEVENLABS_MODEL=eleven_flash_v2_5
# ELEVENLABS_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM


# ═══════════════════════════════════════════════════════════════════════════
# Phase 2 — Firebase Auth (replaces Clerk)
# Required: every authenticated route now verifies a Firebase ID token.
# ═══════════════════════════════════════════════════════════════════════════

# Firebase Admin SDK service account
# Console: https://console.firebase.google.com → your project → Project Settings
#   → Service Accounts → Generate new private key (downloads JSON)
# From that JSON file:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: paste the raw value with literal \n for line breaks (NOT real newlines)
# Example (one line): FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...==\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# Phase 3 — LangSmith (LLM observability)
# Optional — without LANGSMITH_TRACING=true the @traced decorators no-op.
# ═══════════════════════════════════════════════════════════════════════════

# Dashboard: https://smith.langchain.com → Settings → API Keys
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=briefed-dev
# LANGSMITH_TRACING=true


# ═══════════════════════════════════════════════════════════════════════════
# Phase 4 — Supermemory + GitHub webhook
# ═══════════════════════════════════════════════════════════════════════════

# Supermemory (unified doc + meeting + code memory; replaces pgvector)
# Dashboard: https://supermemory.ai → Settings → API Keys
# Without this set, memory.py falls back to the legacy context_chunks pgvector table.
SUPERMEMORY_API_KEY=

# GitHub PAT (used for the initial repo walk; fallback if no GitHub App configured)
# Generate at: https://github.com/settings/tokens (scope: repo for private, public_repo for public)
# GITHUB_TOKEN=

# GitHub App (recommended over PAT for production)
# Setup: https://github.com/settings/apps → New GitHub App
#   - Webhook URL: {PUBLIC_API_BASE}/api/webhooks/github
#   - Webhook secret: generate a strong random value and put it here AND in the App settings
#   - Permissions: Contents (read), Metadata (read)
#   - Subscribe to events: Push
#   - After creating, generate a private key (downloads .pem) and paste below
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# GITHUB_APP_WEBHOOK_SECRET=
