# Supabase (Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Recall.ai (https://docs.recall.ai/) — use the API base for your region, e.g.:
# https://us-east-1.recall.ai | https://eu-central-1.recall.ai | https://ap-northeast-1.recall.ai
RECALL_API_KEY=
RECALL_API_BASE=https://us-east-1.recall.ai

# Public base URL of this FastAPI service (used for realtime webhook URLs in Create Bot).
# Also register the same host + path /api/webhooks/recall/bot-status in the Recall dashboard
# (Bot status change webhooks → Svix).
PUBLIC_API_BASE=

# Google Cloud (Vertex AI + TTS) — local dev uses GOOGLE_APPLICATION_CREDENTIALS; Cloud Run uses attached SA
GCP_PROJECT=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
# Vertex Gemini: GA 2.5 only (default gemini-2.5-pro). Optional: gemini-2.5-flash / gemini-2.5-flash-lite for speed/cost.
# VERTEX_GEMINI_MODEL=gemini-2.5-pro

# Optional: set both webhooks to send header Authorization: Bearer <secret> or X-Webhook-Secret: <secret>
WEBHOOK_SECRET=

# Optional: GitHub API token for repo RAG (private repos & higher rate limits)
# GITHUB_TOKEN=

# Optional: post-meeting brief email via Resend (https://resend.com)
RESEND_API_KEY=
# RESEND_FROM=Briefed <onboarding@resend.dev>

# Browser origins allowed to call this API (comma-separated; include your Vercel URL in production)
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000,http://127.0.0.1:3000
